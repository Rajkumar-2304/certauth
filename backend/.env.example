# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/certauth?retryWrites=true&w=majority

# JWT secret - use a long random string (e.g. from: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here

# App port (Render sets this automatically, keep 5000 as default)
PORT=5000

# Frontend URL for CORS (your Netlify URL)
FRONTEND_URL=https://your-app.netlify.app

# Email credentials (for OTP / certificate emails)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
